# Cloudflare Pages Function secrets (server-side only, never sent to browser)
# Copy this file to .dev.vars and fill in real values for local development

PAGERDUTY_API_KEY=
ABSENCE_API_ID=
ABSENCE_API_KEY=
SENTRY_AUTH_TOKEN=
SENTRY_ORG_SLUG=
SENTRY_PROJECT_SLUG=
GITHUB_TOKEN=
GITHUB_REPOS=myorg/repo1,myorg/repo2,myorg/repo3
CLAUDE_STATS_TOKEN=local-dev-token
CLAUDE_STATS_URL_PROD=https://your-app.pages.dev/api/claude-stats
CLAUDE_STATS_TOKEN_PROD=your-prod-token
